# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Slack — create an app at api.slack.com/apps, add chat:write scope, install to workspace
SLACK_BOT_TOKEN=xoxb-...
# Recipient's Slack user ID — find it in their Slack profile → ··· → Copy member ID
SLACK_USER_ID=U01234567

# Notion — create an internal integration at notion.so/my-integrations
NOTION_API_KEY=secret_...
# The database ID is the 32-char string in the Notion page URL
# e.g. notion.so/myworkspace/abc123...  →  NOTION_DATABASE_ID=abc123...
# Required database properties: Name (title), URL (url), Date (date), Status (select)
NOTION_DATABASE_ID=...

# How often to poll the RSS feed (default: 1 hour)
POLL_INTERVAL_SECONDS=3600
